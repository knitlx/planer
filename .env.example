DATABASE_URL="file:./dev.db"

# CORS origin for API (set to your domain)
NEXT_PUBLIC_APP_URL="https://planer.nochaos.space"

# Session secret - generate with: openssl rand -base64 32
SESSION_SECRET="your-32-char-session-secret-here-min"

# Admin password hash - generate with: node scripts/generate-password-hash.mjs
# Format: base64:xxx (to avoid $ interpolation issues)
ADMIN_PASSWORD_HASH=""

NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_WEBHOOK_SECRET="your-webhook-secret"
TELEGRAM_DEFAULT_CHAT_ID="000000000"

AI_NEWS_LLM_API_URL="https://openrouter.ai/api/v1/chat/completions"
AI_NEWS_LLM_MODEL="openai/gpt-4.1-nano"
AI_NEWS_LLM_API_KEY="set-me"
AI_NEWS_INTERESTS="AI,productivity,developer tooling"

AI_AGENT_API_KEY="set-me"
AI_AGENT_API_BASE="https://api.deepseek.com/v1"
AI_AGENT_MODEL="deepseek-chat"

AI_TRANSCRIBE_API_KEY="set-me"
AI_TRANSCRIBE_API_BASE="https://api.groq.com/openai/v1"
AI_TRANSCRIBE_MODEL="whisper-large-v3-turbo"

# Backup: Run ./scripts/backup-db.sh manually or via cron
# crontab -e: 0 3 * * * /home/knitlx/planer/scripts/backup-db.sh
