generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // URL is configured in prisma.config.ts
}

model Project {
  id              String        @id @default(cuid())
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  name            String
  description     String?
  deadline        DateTime?
  weight          Int           @default(5)
  friction        Int           @default(5)
  progress        Float         @default(0)
  status          ProjectStatus @default(INCUBATOR)
  type            ProjectType   @default(NORMAL)
  todayCompleted  Boolean       @default(false)
  lastCompletedAt DateTime?
  lastActive      DateTime      @default(now())
  lastSessionNote String?
  tasks           Task[]
  ideas           Idea[]
  notificationLogs NotificationLog[]
  reminderTriggerLogs ReminderTriggerLog[]
  habits          Habit[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
}

model Task {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  type            TaskType  @default(ACTION)
  status          TaskStatus @default(TODO)
  isNextStep      Boolean   @default(false)
  order           Int       @default(0)
  timerLog        String?
  contextSummary  String?
  isSimplified    Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([projectId, status])
}

model Idea {
  id                 String              @id @default(cuid())
  content            String
  source             String              @default("Web")
  projectId          String?
  project            Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  processed          Boolean             @default(false)
  status             IdeaStatus          @default(INBOX)
  convertedEntityType ConvertedEntityType?
  convertedEntityId  String?
  createdAt          DateTime            @default(now())

  @@index([processed])
  @@index([status])
}

model NotificationLog {
  id        String   @id @default(cuid())
  type      String
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sentAt    DateTime @default(now())

  @@unique([type, projectId])
  @@index([type, projectId])
}

model User {
  id         String    @id @default(cuid())
  telegramId Int       @unique
  name       String?
  projects   Project[]
  reminders  Reminder[]
  createdAt  DateTime  @default(now())
}

enum ProjectStatus {
  INCUBATOR
  ACTIVE
  SNOOZED
  FINAL_STRETCH
  DONE
}

enum TaskType {
  ACTION
  SESSION
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum IdeaStatus {
  INBOX
  CONVERTED_TO_TASK
  CONVERTED_TO_PROJECT
  ARCHIVED
}

enum ConvertedEntityType {
  TASK
  PROJECT
}

enum ProjectType {
  MANDATORY
  NORMAL
}

model Habit {
  id            String     @id @default(cuid())
  name          String
  description   String?
  projectId     String?
  project       Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  currentStreak Int        @default(0)
  bestStreak    Int        @default(0)
  createdAt     DateTime   @default(now())

  logs          HabitLog[]
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      String
  completed Boolean  @default(false)

  @@unique([habitId, date])
}

model AgentChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Reminder {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  datetime  DateTime
  recurring ReminderRecurring?
  enabled   Boolean        @default(true)
  lastSentAt DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  logs      ReminderLog[]

  @@index([userId])
  @@index([datetime])
  @@index([enabled])
}

model ReminderLog {
  id         String   @id @default(cuid())
  reminderId String
  reminder   Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  sentAt     DateTime @default(now())
  sentDate   String   // Format: YYYY-MM-DD

  @@unique([reminderId, sentDate])
  @@index([reminderId])
  @@index([sentDate])
}

model ReminderTriggerConfig {
  id              String               @id @default(cuid())
  type            ReminderTriggerType
  thresholdDays   Int?
  cooldownHours   Int                  @default(24)
  enabled         Boolean              @default(true)
  lastEvaluatedAt DateTime?
  logs            ReminderTriggerLog[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([type])
}

model ReminderTriggerLog {
  id          String               @id @default(cuid())
  triggerId   String
  trigger     ReminderTriggerConfig @relation(fields: [triggerId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  firedAt     DateTime             @default(now())
  status      ReminderTriggerStatus
  messageHash String?

  @@index([triggerId, firedAt])
  @@index([projectId])
}

model NewsSource {
  id            String          @id @default(cuid())
  name          String
  type          NewsSourceType
  url           String
  enabled       Boolean         @default(true)
  lastFetchedAt DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         NewsRaw[]
}

model NewsRaw {
  id           String            @id @default(cuid())
  sourceId     String
  source       NewsSource        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  title        String
  summary      String?
  url          String
  publishedAt  DateTime?
  hash         String            @unique
  llmInterest  Boolean?
  llmScore     Int?
  classifiedAt DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  digestEntries NewsDigestEntry[]

  @@index([publishedAt])
}

model DigestWindowConfig {
  id        String             @id @default(cuid())
  slug      String             @unique
  timeUtc   String
  enabled   Boolean            @default(true)
  maxItems  Int                @default(5)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  entries   NewsDigestEntry[]
  deliveryLogs DigestDeliveryLog[]
}

model NewsDigestEntry {
  id        String            @id @default(cuid())
  rawId     String
  raw       NewsRaw           @relation(fields: [rawId], references: [id], onDelete: Cascade)
  windowId  String
  window    DigestWindowConfig @relation(fields: [windowId], references: [id], onDelete: Cascade)
  status    DigestEntryStatus  @default(QUEUED)
  position  Int?
  sentAt    DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([windowId, status])
  @@index([status])
}

model DigestDeliveryLog {
  id          String             @id @default(cuid())
  windowId    String
  window      DigestWindowConfig @relation(fields: [windowId], references: [id], onDelete: Cascade)
  deliveredAt DateTime           @default(now())
  itemCount   Int                @default(0)
  messageId   String?

  @@index([windowId, deliveredAt])
}

enum ReminderRecurring {
  DAILY
  WEEKLY
}

enum ReminderTriggerType {
  MANDATORY_STALE
  MANDATORY_IGNORED
  MANDATORY_NO_ACTIVE_TASKS
}

enum ReminderTriggerStatus {
  SENT
  ERROR
  SKIPPED
}

enum NewsSourceType {
  RSS
  API
}

enum DigestEntryStatus {
  QUEUED
  SENT
  SKIPPED
}
